{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/generate-image.js": {
      "maxDuration": 120
    }
  },
  "rewrites": [
    { "source": "/api/generate-image", "destination": "/api/generate-image" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
