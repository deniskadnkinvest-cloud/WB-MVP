{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/generate-image.js": {
      "maxDuration": 300
    },

    "api/payment-webhook.js": {
      "maxDuration": 30
    },
    "api/payment-webhook-yookassa.js": {
      "maxDuration": 10
    },
    "api/create-payment.js": {
      "maxDuration": 10
    },
    "api/cancel-subscription.js": {
      "maxDuration": 10
    },
    "api/send-otp.js": {
      "maxDuration": 10
    },
    "api/verify-otp.js": {
      "maxDuration": 10
    },
    "api/create-tg-session.js": {
      "maxDuration": 10
    },
    "api/complete-tg-auth.js": {
      "maxDuration": 10
    },
    "api/admin.js": {
      "maxDuration": 60
    },
    "api/auth-telegram.js": {
      "maxDuration": 15
    },

    "api/inngest.js": {
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/generate-image", "destination": "/api/generate-image" },

    { "source": "/api/payment-webhook", "destination": "/api/payment-webhook" },
    { "source": "/api/payment-webhook-yookassa", "destination": "/api/payment-webhook-yookassa" },
    { "source": "/api/create-payment", "destination": "/api/create-payment" },
    { "source": "/api/cancel-subscription", "destination": "/api/cancel-subscription" },
    { "source": "/api/send-otp", "destination": "/api/send-otp" },
    { "source": "/api/verify-otp", "destination": "/api/verify-otp" },
    { "source": "/api/create-tg-session", "destination": "/api/create-tg-session" },
    { "source": "/api/complete-tg-auth", "destination": "/api/complete-tg-auth" },

    { "source": "/api/inngest", "destination": "/api/inngest" },
    { "source": "/api/auth-telegram", "destination": "/api/auth-telegram" },
    { "source": "/api/admin/:path*", "destination": "/api/admin.js" },
    { "source": "/__/auth/:path*", "destination": "https://lord-f842d.firebaseapp.com/__/auth/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
