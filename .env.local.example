# ═══════════════════════════════════════════════════════════════
# VTON-MVP Environment Variables
# ═══════════════════════════════════════════════════════════════

# ── Frontend (Vite) ──
# Firebase Console → Project Settings → General → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_APP_URL=https://seller-studio-ai.ru

# ── Backend (Vercel Serverless Functions) ──

# Gemini API
GEMINI_API_KEY=

# KIE.ai (image generation)
KIE_API_KEY=

# Email OTP (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Seller Studio <noreply@aigeorank.ru>

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# Admin Alerts — ID чата/канала для оповещений о платежах и ошибках
# Как узнать: отправьте /start боту @userinfobot в Telegram
TELEGRAM_ADMIN_CHAT_ID=

# Whitelist Telegram ID для доступа к /admin панели
# Несколько ID через запятую: 640128457,987654321
# Как узнать свой ID: /start боту @userinfobot
ADMIN_TELEGRAM_IDS=640128457,130388073

# Firebase Admin SDK (для payment-webhook и verify-panx-token)
# Вариант 1: Полный JSON service account (предпочтительно)
# Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
#
# Вариант 2: Отдельные поля (если Вариант 1 не подходит)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
