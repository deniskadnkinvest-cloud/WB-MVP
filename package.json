{
  "name": "vton-mvp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"VITE,API\" --prefix-colors \"cyan,yellow\" \"vite\" \"node server.js\"",
    "dev:front": "vite",
    "dev:server": "node server.js",
    "lint": "eslint api/*.js",
    "lint:fix": "eslint api/*.js --fix",
    "build": "npm run lint && vite build",
    "preview": "vite preview",
    "catalog:server": "MOCK_KIE=true node server-autocatalog.js",
    "catalog:inngest": "npx inngest-cli@latest dev -u http://localhost:3002/api/inngest",
    "catalog:test": "node test-autocatalog.js"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "@google/genai": "^1.50.1",
    "@imgly/background-removal": "^1.7.0",
    "antd": "^6.4.4",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "framer-motion": "^12.38.0",
    "html-to-image": "^1.11.13",
    "inngest": "^4.4.0",
    "nodemailer": "^6.9.13",
    "openai": "^6.42.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-tools": "^15.15.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "vite": "^8.0.4"
  },
  "lint-staged": {
    "api/*.js": [
      "eslint --max-warnings=0"
    ]
  }
}
