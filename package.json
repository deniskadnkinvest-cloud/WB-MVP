    "test": "node --test tests/revenue.test.js tests/prelaunch-hardening.test.js",
    "test:hardening": "node --test tests/prelaunch-hardening.test.js",
    "test:revenue": "node tests/revenue.test.js",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@google/genai": "^1.50.1",
    "@imgly/background-removal": "^1.7.0",
    "antd": "^6.4.4",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "html-to-image": "^1.11.13",
    "inngest": "^4.4.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^6.9.13",
    "openai": "^6.42.0",
    "pg": "^8.22.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.7.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "vite": "^8.0.4"
  },
  "lint-staged": {
    "api/*.js": [
      "eslint --max-warnings=0 --no-warn-ignored"
